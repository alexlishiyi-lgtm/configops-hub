# Database
DATABASE_URL="postgresql://configops:configops_dev@localhost:5432/configops_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth (Auth.js v5)
AUTH_SECRET="generate-a-random-32-char-string-here"
AUTH_URL="http://localhost:3000"

# GitHub OAuth (Register at https://github.com/settings/developers)
GITHUB_ID="your_github_oauth_id"
GITHUB_SECRET="your_github_oauth_secret"

# Stripe (Sprint 6)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO="price_xxx"
STRIPE_PRICE_TEAM="price_xxx"

# OSS (Sprint 4)
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET="configops-packages"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"
